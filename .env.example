# SQLite (default local demo)
DATABASE_URL="file:./dev.db"

# Postgres (production / docker-compose on port 5433)
# DATABASE_URL="postgresql://aegis:aegis@localhost:5433/aegis"

AUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3010"

# Platform
IDV_VENDOR=MOCK
JURISDICTION_DEFAULT=UK
SESSION_MAX_AGE_HOURS=8
AUDIT_RETENTION_DAYS=2555
RATE_LIMIT_BACKEND=memory
# REDIS_URL=
LOG_LEVEL=info
# APP_VERSION=0.1.0
# FEATURE_FLAGS=securityVertical,careVertical,robotVertical,partnerWhiteLabel

# Evidence storage (AES-256-GCM local; S3 when configured)
STORAGE_BACKEND=local_encrypted
# DOCUMENT_ENCRYPTION_KEY=override-auth-secret-material
# STORAGE_BACKEND=s3
# S3_BUCKET=aegis-evidence
# S3_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Notifications (file outbox; optional HTTP bridge)
NOTIFY_BACKEND=file
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/aegis-mail

# Payments
PAYMENTS_BACKEND=stub
# PAYMENTS_BACKEND=stripe
# STRIPE_SECRET_KEY=sk_live_...

# Multi-instance rate limits (optional)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Domain event webhooks
# DOMAIN_EVENT_WEBHOOK_URL=

# Optional LLM enrichment for document triage (advisory only)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
