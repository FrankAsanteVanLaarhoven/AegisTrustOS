# SQLite (default local demo)
DATABASE_URL="file:./dev.db"

# Postgres (production / docker-compose on port 5433)
# DATABASE_URL="postgresql://aegis:aegis@localhost:5433/aegis"

AUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3010"

# Platform
IDV_VENDOR=MOCK
JURISDICTION_DEFAULT=UK
SESSION_MAX_AGE_HOURS=8
AUDIT_RETENTION_DAYS=2555
RATE_LIMIT_BACKEND=memory
# REDIS_URL=
LOG_LEVEL=info
# APP_VERSION=0.1.0
# FEATURE_FLAGS=securityVertical,careVertical,robotVertical,partnerWhiteLabel

# Evidence storage (AES-256-GCM local; S3 adapter later)
STORAGE_BACKEND=local_encrypted
# DOCUMENT_ENCRYPTION_KEY=override-auth-secret-material
# S3_BUCKET=
# S3_REGION=

# Notifications (file outbox → SES/Postmark later)
NOTIFY_BACKEND=file

# Payments (stub → Stripe Connect later)
PAYMENTS_BACKEND=stub
# STRIPE_SECRET_KEY=

# Optional LLM enrichment for document triage (advisory only)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
