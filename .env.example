# ── Database ──────────────────────────────────────────────
# SQLite (default local demo)
DATABASE_URL="file:./dev.db"

# Postgres (docker compose on port 5433)
# DATABASE_URL="postgresql://aegis:aegis@localhost:5433/aegis"

# ── Auth ──────────────────────────────────────────────────
AUTH_SECRET="generate-a-long-random-string-at-least-32-chars"
NEXTAUTH_URL="http://localhost:3010"

# ── Platform ──────────────────────────────────────────────
IDV_VENDOR=MOCK
# IDV_VENDOR=TRULIOO | SOCURE
# IDV_WEBHOOK_SECRET=required-when-not-mock-in-prod
# TRULIOO_API_KEY=
# TRULIOO_BASE_URL=
# SOCURE_API_KEY=
# SOCURE_BASE_URL=
JURISDICTION_DEFAULT=UK
SESSION_MAX_AGE_HOURS=8
AUDIT_RETENTION_DAYS=2555
RATE_LIMIT_BACKEND=memory
# RATE_LIMIT_BACKEND=redis
# REDIS_URL=
LOG_LEVEL=info
# APP_VERSION=0.1.0
# FEATURE_FLAGS=securityVertical,careVertical,robotVertical,partnerWhiteLabel,payments,webhooks

# ── Evidence storage ──────────────────────────────────────
STORAGE_BACKEND=local_encrypted
# DOCUMENT_ENCRYPTION_KEY=override-auth-secret-material
# STORAGE_BACKEND=s3
# S3_BUCKET=aegis-evidence
# S3_REGION=eu-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Notifications ─────────────────────────────────────────
NOTIFY_BACKEND=file
# NOTIFY_BACKEND=webhook | postmark | ses
# NOTIFY_WEBHOOK_URL=https://hooks.example.com/aegis-mail
# NOTIFY_FROM_EMAIL=noreply@yourdomain.com
# POSTMARK_SERVER_TOKEN=
# SES_REGION=eu-west-2
# PILOT_NOTIFY_EMAIL=ops@yourdomain.com

# ── Payments (Connect marketplace) ────────────────────────
PAYMENTS_BACKEND=stub
# PAYMENTS_BACKEND=stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PLATFORM_FEE_BPS=1500

# ── Multi-instance rate limits ────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Domain event webhooks ─────────────────────────────────
# DOMAIN_EVENT_WEBHOOK_URL=

# ── CI/CD / cron ──────────────────────────────────────────
# CRON_SECRET=long-random-for-vercel-and-github-actions
# Same value in Vercel project env + GitHub Actions secret

# ── Optional LLM enrichment (advisory only) ───────────────
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
