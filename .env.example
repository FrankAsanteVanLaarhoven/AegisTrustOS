# SQLite (default local demo)
DATABASE_URL="file:./dev.db"

# Postgres (production / docker-compose on port 5433)
# DATABASE_URL="postgresql://aegis:aegis@localhost:5433/aegis"

AUTH_SECRET="generate-a-long-random-string"
NEXTAUTH_URL="http://localhost:3010"

# Platform
# IDV_VENDOR=MOCK|TRULIOO|SOCURE
IDV_VENDOR=MOCK
JURISDICTION_DEFAULT=UK
SESSION_MAX_AGE_HOURS=8
AUDIT_RETENTION_DAYS=2555
RATE_LIMIT_BACKEND=memory
# REDIS_URL=
LOG_LEVEL=info
# APP_VERSION=0.1.0
# FEATURE_FLAGS=securityVertical,careVertical,partnerWhiteLabel
# FEATURE_FLAGS=-careVertical  (disable care)

# Optional: LLM enrichment for CV/credential text extraction (advisory only)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
